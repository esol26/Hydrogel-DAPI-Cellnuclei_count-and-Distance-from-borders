def px_area_to_mm2(area_px: int, px_per_um: float) -> float:
    area_um2 = float(area_px) / float(px_per_um * px_per_um)
    return area_um2 / 1e6


def ring_area_mm2(outer_inside: np.ndarray, inner_inside: np.ndarray, px_per_um: float) -> float:
    ring = outer_inside & (~inner_inside)
    return px_area_to_mm2(int(ring.sum()), px_per_um)



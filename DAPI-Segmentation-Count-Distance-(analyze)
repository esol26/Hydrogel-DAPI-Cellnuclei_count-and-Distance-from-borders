def distanzklasse_text_de(class_code: int, thresholds_um: List[float]) -> str:
    """
    Gewünschte Benennung in der Summary:
      - bei genau 2 Schwellen -> 3 Klassen: nah, mittel, fern
      - sonst generisch: Klasse 1..N
    """
    if class_code <= 0:
        return "NA"

    if len(thresholds_um) == 2:
        if class_code == 1:
            return "nah"
        if class_code == 2:
            return "mittel"
        if class_code == 3:
            return "fern"
        return f"Klasse {class_code}"

    return f"Klasse {class_code}"


def teilzone_text_de(subzone: str) -> str:
    s = str(subzone).strip().lower()
    if s == "outer_only":
        return "Aussengrenze-nah"
    if s == "inner_only":
        return "Innengrenze-nah"
    if s == "overlap":
        return "Überlappung"
    if s == "total":
        return "Gesamt"
    if s in ("all", "gesamt"):
        return "gesamt"
    return subzone

def build_summary_df(
    image_name: str,
    df_objects: pd.DataFrame,
    do_distances: bool,
    px_per_um: float,
    outer_inside: Optional[np.ndarray],
    inner_inside: Optional[np.ndarray],
    area_by_class_subzone_mm2: Optional[pd.DataFrame],
    thresholds_um: List[float],
) -> pd.DataFrame:
    # Ringfläche
    ring_area = np.nan
    if do_distances and outer_inside is not None and inner_inside is not None:
        ring_area = ring_area_mm2(outer_inside, inner_inside, px_per_um)

    # Included-Filter
    if "Included" in df_objects.columns and len(df_objects) > 0:
        df_inc = df_objects[df_objects["Included"] == 1].copy()
    else:
        df_inc = df_objects.copy()

    gesamt_anzahl = int(len(df_inc))
    gesamt_dichte = (gesamt_anzahl / ring_area) if (ring_area == ring_area and ring_area > 0) else np.nan

    rows: List[Dict[str, Any]] = []

    # 1) Gesamtzeile
    rows.append({
        "Bildname": image_name,
        "Zeilentyp": "Gesamt",
        "Distanzklasse_Code": np.nan,
        "Distanzklasse": "gesamt",
        "Teilzone": "gesamt",
        "Zellkerne_Anzahl": gesamt_anzahl,
        "Anteil_Zellkerne_Prozent": 100.0 if gesamt_anzahl > 0 else 0.0,
        "Fläche_mm2_geschätzt": float(ring_area) if ring_area == ring_area else np.nan,
        "Anteil_Fläche_Prozent": 100.0 if (ring_area == ring_area and ring_area > 0) else np.nan,
        "Dichte_Zellkerne_pro_mm2": float(gesamt_dichte) if gesamt_dichte == gesamt_dichte else np.nan,
    })

    if do_distances:
        # Klassenanzahl: bei Schwellenliste Länge k -> k+1 Klassen
        n_classes = len(thresholds_um) + 1

        for cls in range(1, n_classes + 1):
            cls_txt = distanzklasse_text_de(cls, thresholds_um)

            mask_cls = (df_inc["DistanceClass"] == cls) if ("DistanceClass" in df_inc.columns and len(df_inc) > 0) else np.zeros((len(df_inc),), dtype=bool)
            count_total = int(mask_cls.sum())

            # Fläche dieser Klasse = Summe der Teilzonenflächen (falls vorhanden)
            area_total = np.nan
            if area_by_class_subzone_mm2 is not None and len(area_by_class_subzone_mm2) > 0:
                m = (area_by_class_subzone_mm2["DistanceClass"] == cls)
                area_total = float(area_by_class_subzone_mm2.loc[m, "Area_mm2_est"].sum())
                if area_total <= 0:
                    area_total = np.nan

            dens_total = (count_total / area_total) if (area_total == area_total and area_total > 0) else np.nan
            perc_nuc_total = (count_total / gesamt_anzahl * 100.0) if gesamt_anzahl > 0 else 0.0
            perc_area_total = (area_total / ring_area * 100.0) if (ring_area == ring_area and ring_area > 0 and pd.notna(area_total)) else np.nan

            rows.append({
                "Bildname": image_name,
                "Zeilentyp": "Distanzklasse_Gesamt",
                "Distanzklasse_Code": cls,
                "Distanzklasse": cls_txt,
                "Teilzone": teilzone_text_de("total"),
                "Zellkerne_Anzahl": count_total,
                "Anteil_Zellkerne_Prozent": float(perc_nuc_total),
                "Fläche_mm2_geschätzt": float(area_total) if pd.notna(area_total) else np.nan,
                "Anteil_Fläche_Prozent": float(perc_area_total) if pd.notna(perc_area_total) else np.nan,
                "Dichte_Zellkerne_pro_mm2": float(dens_total) if pd.notna(dens_total) else np.nan,
            })

            # Teilzonen: HG-Rand-nah / HF-Rand-nah / Überlappung
            for subz in ["outer_only", "inner_only", "overlap"]:
                mask_sub = mask_cls & (df_inc["DistanceSubzone"] == subz) if ("DistanceSubzone" in df_inc.columns and len(df_inc) > 0) else np.zeros((len(df_inc),), dtype=bool)
                count_sub = int(mask_sub.sum())

                area_sub = np.nan
                if area_by_class_subzone_mm2 is not None and len(area_by_class_subzone_mm2) > 0:
                    m = (area_by_class_subzone_mm2["DistanceClass"] == cls) & (area_by_class_subzone_mm2["DistanceSubzone"] == subz)
                    if int(m.sum()) > 0:
                        area_sub = float(area_by_class_subzone_mm2.loc[m, "Area_mm2_est"].sum())
                    if area_sub <= 0:
                        area_sub = np.nan

                dens_sub = (count_sub / area_sub) if (area_sub == area_sub and area_sub > 0) else np.nan
                perc_nuc_sub = (count_sub / gesamt_anzahl * 100.0) if gesamt_anzahl > 0 else 0.0
                perc_area_sub = (area_sub / ring_area * 100.0) if (ring_area == ring_area and ring_area > 0 and pd.notna(area_sub)) else np.nan

                rows.append({
                    "Bildname": image_name,
                    "Zeilentyp": "Distanzklasse_Teilzone",
                    "Distanzklasse_Code": cls,
                    "Distanzklasse": cls_txt,
                    "Teilzone": teilzone_text_de(subz),
                    "Zellkerne_Anzahl": count_sub,
                    "Anteil_Zellkerne_Prozent": float(perc_nuc_sub),
                    "Fläche_mm2_geschätzt": float(area_sub) if pd.notna(area_sub) else np.nan,
                    "Anteil_Fläche_Prozent": float(perc_area_sub) if pd.notna(perc_area_sub) else np.nan,
                    "Dichte_Zellkerne_pro_mm2": float(dens_sub) if pd.notna(dens_sub) else np.nan,
                })

    return pd.DataFrame(rows)


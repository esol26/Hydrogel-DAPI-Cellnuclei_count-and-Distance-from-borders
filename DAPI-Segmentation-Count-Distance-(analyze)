def safe_stem(s: str, max_len: int = 60) -> str:
    s = str(s).strip()
    s = re.sub(r"[^A-Za-z0-9._-]+", "_", s)
    s = re.sub(r"_+", "_", s).strip("_")
    if len(s) > int(max_len):
        s = s[: int(max_len)]
    return s if s else "file"


def make_run_output_dir(parent_dir: str, dapi_path: str, max_basename_len: int = 60) -> Tuple[str, str, str]:
    base_original = os.path.splitext(os.path.basename(dapi_path))[0]
    base_safe = safe_stem(base_original, max_len=max_basename_len)
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    results_root = os.path.join(parent_dir, "dapi_results")
    out_dir = os.path.join(results_root, f"{base_safe}_{ts}")
    os.makedirs(out_dir, exist_ok=False)
    return out_dir, base_safe, base_original


def save_run_artifacts(out_dir: str):
    try:
        this_file = os.path.abspath(__file__)
        shutil.copyfile(this_file, os.path.join(out_dir, "used_code.txt"))
    except Exception as e:
        with open(os.path.join(out_dir, "used_code_error.txt"), "w", encoding="utf-8") as f:
            f.write(str(e) + "\n")


def write_csv(df: pd.DataFrame, path: str, sep: str, decimal: str, round_decimals: Optional[int] = None):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    out = df.copy()
    if round_decimals is not None:
        num_cols = out.select_dtypes(include=[np.number]).columns
        if len(num_cols) > 0:
            out[num_cols] = out[num_cols].round(int(round_decimals))
    out.to_csv(path, index=False, sep=str(sep), decimal=str(decimal))


def read_image_any(path: str) -> np.ndarray:
    ext = os.path.splitext(path)[1].lower()
    if ext in [".tif", ".tiff"]:
        return tiff.imread(path)

    img = cv2.imread(path, cv2.IMREAD_UNCHANGED)
    if img is None:
        raise ValueError(f"Could not read image: {path}")

    if img.ndim == 3 and img.shape[2] == 3:
        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    elif img.ndim == 3 and img.shape[2] == 4:
        img = cv2.cvtColor(img, cv2.COLOR_BGRA2RGBA)
    return img


def to_float01(img: np.ndarray) -> np.ndarray:
    img = img.astype(np.float32, copy=False)
    mn = float(np.nanmin(img))
    mx = float(np.nanmax(img))
    if mx <= mn:
        return np.zeros_like(img, dtype=np.float32)
    return (img - mn) / (mx - mn)


def as_gray(img: np.ndarray) -> np.ndarray:
    if img.ndim == 2:
        return img
    if img.ndim == 3:
        if img.shape[-1] in (3, 4):
            return np.max(img[..., :3], axis=-1)
        if img.shape[0] in (3, 4):
            return np.max(img[:3, ...], axis=0)
        return np.max(img, axis=0)
    raise ValueError(f"Unsupported image shape: {img.shape}")


def extract_blue_channel(dapi: np.ndarray) -> np.ndarray:
    if dapi.ndim == 2:
        return dapi
    if dapi.ndim == 3 and dapi.shape[-1] >= 3:
        return dapi[..., 2]
    if dapi.ndim == 3 and dapi.shape[0] >= 3:
        return dapi[2, ...]
    return as_gray(dapi)


# ======================================================================================
# PNG writing (unicode-safe)
# ======================================================================================
def write_png_unicode_safe(path: str, img: np.ndarray, png_compression: int = 1):
    png_compression = int(max(0, min(9, int(png_compression))))
    if os.path.splitext(path)[1].lower() != ".png":
        raise ValueError(f"Expected .png output path, got: {path}")

    ok, buf = cv2.imencode(".png", img, [cv2.IMWRITE_PNG_COMPRESSION, png_compression])
    if not ok:
        raise IOError(f"cv2.imencode failed for PNG: {path}")

    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "wb") as f:
        f.write(buf.tobytes())


def save_bool_png(path: str, mask: np.ndarray, png_compression: int = 1):
    img8 = (mask.astype(np.uint8) * 255)
    write_png_unicode_safe(path, img8, png_compression)



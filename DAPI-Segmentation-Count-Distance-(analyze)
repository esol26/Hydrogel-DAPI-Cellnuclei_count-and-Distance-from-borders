def make_classes_image_rgb_lut(labels: np.ndarray, df: pd.DataFrame, thresholds_um: List[float]) -> np.ndarray:
    max_label = int(labels.max())
    lut = np.zeros((max_label + 1, 3), dtype=np.uint8)

    if len(df) == 0 or "ObjectID" not in df.columns:
        return lut[labels]

    for _, r in df.iterrows():
        oid = int(r["ObjectID"])
        included = bool(int(r.get("Included", 1)))
        class_code = int(r.get("DistanceClass", 0))
        if 0 <= oid <= max_label:
            lut[oid] = np.array(class_to_color_rgb(class_code, included, thresholds_um), dtype=np.uint8)

    return lut[labels]



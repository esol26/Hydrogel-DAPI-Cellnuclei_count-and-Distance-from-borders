def analyze_one(
    dapi_path: str,
    out_dir: str,
    base_safe: str,
    base_original: str,
    params: dict,
    do_distances: bool,
    outer_path: Optional[str],
    inner_path: Optional[str],
    log_fn=None,
    abort_event: Optional[threading.Event] = None,
):
    def log(msg: str):
        if log_fn:
            log_fn(msg)
        else:
            print(msg)

    abort_check(abort_event)

    thresholds_um: List[float] = params["thresholds_um"]
    px_per_um = float(params["px_per_um"])
    png_comp = int(params["png_compression"])
    csv_sep = str(params["csv_sep"])
    csv_decimal = str(params["csv_decimal"])
    round_dec = int(params["summary_round_decimals"])

    # run log
    with open(os.path.join(out_dir, "run_log.txt"), "w", encoding="utf-8") as f:
        f.write(f"VERSION: {DAPI_ANALYZE_GUI_VERSION}\n")
        f.write(f"DAPI: {dapi_path}\n")
        f.write(f"do_distances: {do_distances}\n")
        f.write(f"OUTER: {outer_path}\n")
        f.write(f"INNER: {inner_path}\n")
        f.write(f"base_original: {base_original}\n")
        f.write(f"base_safe: {base_safe}\n")
        for k in sorted(params.keys()):
            f.write(f"{k}: {params[k]}\n")

    log("Loading DAPI...")
    dapi = read_image_any(dapi_path)
    dapi_blue = extract_blue_channel(dapi)
    h, w = dapi_blue.shape[:2]
    log(f"Image size: {h} x {w} px")

    abort_check(abort_event)

    # boundaries
    outer_inside = inner_inside = None
    outer_bin = inner_bin = None
    outer_tree = inner_tree = None
    outer_mode = inner_mode = "NA"
    outer_n = inner_n = 0

    if do_distances:
        if not outer_path or not inner_path:
            raise ValueError("Distance mode selected but OUTER/INNER not provided.")

        outer_img = read_image_any(outer_path)
        inner_img = read_image_any(inner_path)

        if as_gray(outer_img).shape[:2] != (h, w) or as_gray(inner_img).shape[:2] != (h, w):
            raise ValueError("Image sizes do not match (DAPI vs boundaries).")

        debug_dir = out_dir if bool(params.get("save_debug_boundary_masks", True)) else None
        log("Binarizing boundaries + building KDTree...")
        outer_bin, outer_inside, outer_mode = binarize_boundary_line(
            outer_img, debug_dir=debug_dir, tag=f"{base_safe}_outer", png_compression=png_comp
        )
        inner_bin, inner_inside, inner_mode = binarize_boundary_line(
            inner_img, debug_dir=debug_dir, tag=f"{base_safe}_inner", png_compression=png_comp
        )

        outer_tree, outer_n = build_kdtree_from_boundary(outer_bin, bool(params.get("skeletonize_boundary", True)))
        inner_tree, inner_n = build_kdtree_from_boundary(inner_bin, bool(params.get("skeletonize_boundary", True)))

        log(f"Boundary modes: outer={outer_mode} (pts={outer_n}), inner={inner_mode} (pts={inner_n})")

    abort_check(abort_event)

    # segmentation
    log("Segmenting nuclei...")
    labels, nuclei_mask = make_nuclei_labels(
        dapi_blue=dapi_blue,
        gaussian_sigma=float(params["gaussian_sigma"]),
        local_radius_px=int(params["local_radius_px"]),
        do_watershed=bool(params["do_watershed"]),
        watershed_h_px=float(params["watershed_h_px"]),
        exclude_edge=bool(params["exclude_edge"]),
        min_size_px2=int(params["min_size_px2"]),
        max_size_px2=int(params["max_size_px2"]),
        remove_line_artifacts_flag=bool(params.get("remove_line_artifacts", True)),
        line_max_h=int(params.get("line_artifact_max_h_px", 2)),
        line_min_w=int(params.get("line_artifact_min_w_px", 80)),
        line_min_aspect=float(params.get("line_artifact_min_aspect", 15.0)),
    )

    if bool(params.get("save_debug_nuclei_mask", False)):
        save_bool_png(os.path.join(out_dir, f"{base_safe}_DEBUG_nuclei_mask.png"), nuclei_mask, png_compression=png_comp)

    abort_check(abort_event)

    # regionprops -> object table
    img01 = to_float01(dapi_blue)
    tbl = measure.regionprops_table(
        labels,
        intensity_image=img01,
        properties=("label", "area", "centroid", "mean_intensity"),
    )
    n_obj = len(tbl["label"])
    log(f"Building object table for {n_obj} objects...")

    rows = []
    check_every = int(params.get("abort_check_every_n_objects", 256))
    for i in range(n_obj):
        if check_every > 0 and (i % check_every == 0):
            abort_check(abort_event)

        oid = int(tbl["label"][i])
        y = int(round(float(tbl["centroid-0"][i])))
        x = int(round(float(tbl["centroid-1"][i])))
        x = max(0, min(w - 1, x))
        y = max(0, min(h - 1, y))

        area_px2 = float(tbl["area"][i])
        area_um2 = float(area_px2) / float(px_per_um * px_per_um)
        mean_int = float(tbl["mean_intensity"][i])

        if do_distances:
            inside_outer = bool(outer_inside[y, x])
            inside_inner = bool(inner_inside[y, x])
            excluded_outside_outer = int(not inside_outer)
            excluded_inside_inner = int(inside_inner)
            included = int((excluded_outside_outer == 0) and (excluded_inside_inner == 0))

            d_outer_px = float(outer_tree.query([float(y), float(x)], k=1)[0])
            d_inner_px = float(inner_tree.query([float(y), float(x)], k=1)[0])
            d_outer_um = d_outer_px / float(px_per_um)
            d_inner_um = d_inner_px / float(px_per_um)

            if included:
                d_min_px = float(min(d_outer_px, d_inner_px))
                d_min_um = d_min_px / float(px_per_um)
                c_min = classify_by_thresholds(float(d_min_um), thresholds_um)
                c_outer = classify_by_thresholds(float(d_outer_um), thresholds_um)
                c_inner = classify_by_thresholds(float(d_inner_um), thresholds_um)
                sub = distance_subzone_from_classes(c_min, c_outer, c_inner)
                c_txt = class_label(c_min, thresholds_um)
            else:
                d_min_px = -1.0
                d_min_um = -1.0
                c_min = c_outer = c_inner = 0
                sub = "none"
                c_txt = "EXCLUDED"
        else:
            inside_outer = inside_inner = False
            excluded_outside_outer = excluded_inside_inner = 0
            included = 1

            d_outer_px = d_inner_px = d_min_px = -1.0
            d_outer_um = d_inner_um = d_min_um = -1.0
            c_min = c_outer = c_inner = 0
            sub = "none"
            c_txt = "NA"

        rows.append({
            "ObjectID": oid,
            "Included": included,
            "ExcludedOutsideOuter": excluded_outside_outer,
            "ExcludedInsideInner": excluded_inside_inner,
            "InsideOuter": int(inside_outer),
            "InsideInner": int(inside_inner),
            "X_px": x,
            "Y_px": y,
            "X_um": float(x / px_per_um),
            "Y_um": float(y / px_per_um),
            "Area_px2": area_px2,
            "Area_um2": area_um2,
            "MeanIntensity": mean_int,
            "DistOuterRaw_px": d_outer_px,
            "DistInnerRaw_px": d_inner_px,
            "DistMinDirected_px": d_min_px,
            "DistOuterRaw_um": d_outer_um,
            "DistInnerRaw_um": d_inner_um,
            "DistMinDirected_um": d_min_um,
            "DistanceClass": int(c_min),
            "DistanceClassLabel": c_txt,
            "DistanceClassOuter": int(c_outer),
            "DistanceClassInner": int(c_inner),
            "DistanceSubzone": sub,
        })

    df_objects = pd.DataFrame(rows, columns=EXPECTED_OBJECT_COLUMNS)

    objects_path = os.path.join(out_dir, f"{base_safe}_all_data.csv")
    write_csv(df_objects, objects_path, sep=csv_sep, decimal=csv_decimal, round_decimals=None)
    log(f"Wrote: {objects_path}")

    abort_check(abort_event)

    # Heatmap: fixed count scale 0..25
    if bool(params.get("save_local_density_map", True)):
        cell_um = float(params.get("density_cell_um", 100.0))
        use_ring = bool(params.get("density_use_ring_if_available", True)) and bool(do_distances) and (outer_inside is not None) and (inner_inside is not None)

        area_mask = None
        if use_ring:
            area_mask = (outer_inside & (~inner_inside))
        else:
            if bool(params.get("density_tissue_mask_from_nuclei", True)):
                ds_m = int(params.get("density_tissue_mask_ds", 8))
                dil_um = float(params.get("density_tissue_dilate_um", 60.0))
                clo_um = float(params.get("density_tissue_close_um", 40.0))
                log(f"Building tissue mask for heatmap (from nuclei_mask, ds={ds_m}, dilate={dil_um}µm, close={clo_um}µm)...")
                area_mask = build_tissue_mask_from_nuclei_mask_downsampled(
                    nuclei_mask=nuclei_mask,
                    px_per_um=px_per_um,
                    ds=ds_m,
                    dilate_um=dil_um,
                    close_um=clo_um,
                )

        if bool(params.get("save_density_mask_debug", False)) and area_mask is not None:
            save_bool_png(os.path.join(out_dir, f"{base_safe}_DEBUG_heatmap_area_mask.png"), area_mask.astype(bool), png_compression=png_comp)

        if len(df_objects) == 0:
            log("No nuclei -> skipping heatmap.")
        else:
            xs = df_objects["X_px"].to_numpy(dtype=np.int32)
            ys = df_objects["Y_px"].to_numpy(dtype=np.int32)

            if use_ring and bool(params.get("density_use_included_only", True)):
                m = (df_objects["Included"].to_numpy(dtype=np.int32) == 1)
                xs = xs[m]
                ys = ys[m]

            log("Building local grid stats + tiles CSV...")
            density_grid, counts_grid, cell_px, tiles_df = compute_local_density_grid_and_tiles(
                xs_px=xs,
                ys_px=ys,
                h=h,
                w=w,
                px_per_um=px_per_um,
                cell_um=cell_um,
                area_mask_anyshape=area_mask,
            )

            if bool(params.get("save_local_density_tiles_csv", True)):
                tiles_path = os.path.join(out_dir, f"{base_safe}_local_density_tiles_cell{cell_um:g}um.csv")
                write_csv(tiles_df, tiles_path, sep=csv_sep, decimal=csv_decimal, round_decimals=round_dec)
                log(f"Wrote: {tiles_path}")

            vmin = float(params.get("heatmap_fixed_count_vmin", 0.0))
            vmax = float(params.get("heatmap_fixed_count_vmax", 25.0))
            valid_tiles = np.isfinite(density_grid)

            colormap = str(params.get("density_colormap", "turbo"))
            bgr_grid = counts_to_colormap_bgr_fixed(
                counts=counts_grid,
                vmin=vmin,
                vmax=vmax,
                colormap=colormap,
                excluded_gray=int(params.get("density_excluded_gray", 0)),
                valid_mask=valid_tiles,
            )

            heat_up = cv2.resize(
                bgr_grid,
                (bgr_grid.shape[1] * cell_px, bgr_grid.shape[0] * cell_px),
                interpolation=cv2.INTER_NEAREST,
            )

            if bool(params.get("density_embed_colorbar", True)) and bool(params.get("density_show_colorbar", True)):
                side = str(params.get("density_colorbar_side", "right"))
                cb = make_colormap_colorbar_bgr(
                    vmin=vmin,
                    vmax=vmax,
                    colormap=colormap,
                    width=int(params.get("density_colorbar_width", 120)),
                    height=heat_up.shape[0] if side.lower() == "right" else 180,
                    title="nuclei/tile",
                )
                heat_up = embed_colorbar_into_heatmap(
                    heat_bgr=heat_up,
                    colorbar_bgr=cb,
                    side=side,
                    pad=int(params.get("density_colorbar_padding", 10)),
                )

            out_heat = os.path.join(out_dir, f"{base_safe}_heatmap_counts_{colormap}_cell{cell_um:g}um_vmax{vmax:g}.png")
            write_png_unicode_safe(out_heat, heat_up, png_comp)
            log(f"Wrote: {out_heat}")

    abort_check(abort_event)

    # Area by class/subzone for summary (optional but needed for Area/%/Density columns)
    area_by_class_subzone_mm2 = None
    if do_distances and bool(params.get("compute_zone_area_for_density", True)):
        ds_area = int(params.get("density_area_downsample_factor", 8))
        log(f"Estimating area by DistanceClass+Subzone (ds={ds_area})...")
        area_by_class_subzone_mm2 = estimate_area_by_class_and_subzone_mm2(
            outer_inside=outer_inside,
            inner_inside=inner_inside,
            outer_tree=outer_tree,
            inner_tree=inner_tree,
            px_per_um=px_per_um,
            thresholds_um=thresholds_um,
            ds=ds_area,
            abort_event=abort_event,
        )

    # Summary
    df_summary = build_summary_df(
        image_name=base_original,
        df_objects=df_objects,
        do_distances=do_distances,
        px_per_um=px_per_um,
        outer_inside=outer_inside,
        inner_inside=inner_inside,
        area_by_class_subzone_mm2=area_by_class_subzone_mm2,
        thresholds_um=thresholds_um,
    )
    summary_path = os.path.join(out_dir, f"{base_safe}_summary.csv")
    write_csv(df_summary, summary_path, sep=csv_sep, decimal=csv_decimal, round_decimals=round_dec)
    log(f"Wrote: {summary_path}")

    abort_check(abort_event)

    # analysis_info
    ring_area = ring_area_mm2(outer_inside, inner_inside, px_per_um) if (do_distances and outer_inside is not None and inner_inside is not None) else float("nan")
    write_analysis_info_txt(
        path=os.path.join(out_dir, f"{base_safe}_analysis_info.txt"),
        dapi_path=dapi_path,
        outer_path=outer_path,
        inner_path=inner_path,
        params=params,
        do_distances=do_distances,
        h=h,
        w=w,
        px_per_um=px_per_um,
        thresholds_um=thresholds_um,
        outer_mode=str(outer_mode),
        inner_mode=str(inner_mode),
        outer_n=int(outer_n),
        inner_n=int(inner_n),
        ring_area_mm2_val=float(ring_area) if ring_area == ring_area else float("nan"),
    )
    log("Wrote: analysis_info.txt")

    abort_check(abort_event)

    # distance zones image
    if do_distances and bool(params.get("save_distance_zones_image", True)):
        ds = int(params.get("zones_downsample_factor", 8))
        log(f"Building distance zones image (ds={ds})...")
        zones_rgb = build_distance_zones_image_downsampled_rgb_with_overlap(
            outer_inside=outer_inside,
            inner_inside=inner_inside,
            outer_bin=outer_bin,
            inner_bin=inner_bin,
            outer_tree=outer_tree,
            inner_tree=inner_tree,
            px_per_um=px_per_um,
            thresholds_um=thresholds_um,
            ds=ds,
            overlay_boundaries_blue=bool(params.get("zones_overlay_boundaries_blue", True)),
            overlap_darken_factor=float(params.get("zones_overlap_darken_factor", 0.65)),
            abort_event=abort_event,
        )
        zones_bgr = cv2.cvtColor(zones_rgb, cv2.COLOR_RGB2BGR)
        out_path = os.path.join(out_dir, f"{base_safe}_distance_zones_ds{ds}.png")
        write_png_unicode_safe(out_path, zones_bgr, png_comp)
        log(f"Wrote: {out_path}")

    abort_check(abort_event)

    # classes_filled image
    if do_distances and bool(params.get("save_classes_filled", True)):
        viz_ds = int(params.get("viz_downsample_factor", 1))
        suffix = f"_ds{viz_ds}" if viz_ds != 1 else ""
        log(f"Creating classes_filled (ds={viz_ds})...")
        labels_v = labels if viz_ds == 1 else labels[::viz_ds, ::viz_ds]
        classes_rgb = make_classes_image_rgb_lut(labels_v, df_objects, thresholds_um)
        classes_bgr = cv2.cvtColor(classes_rgb, cv2.COLOR_RGB2BGR)
        out_path = os.path.join(out_dir, f"{base_safe}_classes_filled{suffix}.png")
        write_png_unicode_safe(out_path, classes_bgr, png_comp)
        log(f"Wrote: {out_path}")

    with open(os.path.join(out_dir, "run_info.txt"), "w", encoding="utf-8") as f:
        f.write(f"VERSION: {DAPI_ANALYZE_GUI_VERSION}\n")
        f.write(f"do_distances: {do_distances}\n")
        f.write(f"Image size: {h} x {w} px\n")
        f.write(f"outer_mode: {outer_mode}\n")
        f.write(f"inner_mode: {inner_mode}\n")



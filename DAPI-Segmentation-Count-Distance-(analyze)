    def _collect_params(self) -> Dict[str, Any]:
        mode = str(self.run_mode.get())
        do_distances = mode in ("distance_csv", "distance_with_images", "batch")

        px_per_um = float(self.v_px_per_um.get())
        if px_per_um <= 0:
            raise ValueError("Pixel pro µm muss > 0 sein.")

        thresholds_um = parse_thresholds_list(self.v_thresholds.get())

        png_comp = int(float(self.v_png_comp.get()))
        if png_comp < 0 or png_comp > 9:
            raise ValueError("PNG Kompression muss 0..9 sein.")

        max_base_len = int(float(self.v_max_base_len.get()))
        if max_base_len < 10:
            raise ValueError("Max filename stem length sollte >= 10 sein.")

        density_cell_um = float(self.v_density_cell_um.get())
        if density_cell_um <= 0:
            raise ValueError("Heatmap cell size muss > 0 sein.")

        density_colormap = str(self.v_density_colormap.get()).strip().lower()
        if density_colormap not in ("turbo", "jet"):
            raise ValueError("Colormap muss turbo oder jet sein.")

        params: Dict[str, Any] = {
            "px_per_um": px_per_um,
            "thresholds_um": thresholds_um,

            "min_size_px2": int(float(self.v_min_size.get())),
            "max_size_px2": int(float(self.v_max_size.get())),
            "gaussian_sigma": float(self.v_sigma.get()),
            "local_radius_px": int(float(self.v_radius.get())),

            "do_watershed": bool(self.v_watershed.get()),
            "watershed_h_px": float(self.v_watershed_h.get()),
            "exclude_edge": bool(self.v_exclude_edge.get()),
            "skeletonize_boundary": bool(self.v_skeletonize.get()),

            # outputs (ONLY)
            "save_classes_filled": bool(self.v_save_classes.get()),
            "save_distance_zones_image": bool(self.v_save_zones.get()),
            "save_local_density_map": bool(self.v_save_local_density.get()),

            "density_cell_um": density_cell_um,
            "density_colormap": density_colormap,
            "density_show_colorbar": bool(DEFAULTS["density_show_colorbar"]),
            "density_embed_colorbar": bool(self.v_density_embed.get()),
            "density_colorbar_side": str(DEFAULTS["density_colorbar_side"]),
            "density_colorbar_width": int(DEFAULTS["density_colorbar_width"]),
            "density_colorbar_padding": int(DEFAULTS["density_colorbar_padding"]),
            "density_excluded_gray": int(DEFAULTS["density_excluded_gray"]),

            "density_use_ring_if_available": bool(DEFAULTS["density_use_ring_if_available"]),
            "density_use_included_only": bool(DEFAULTS["density_use_included_only"]),
            "density_tissue_mask_from_nuclei": bool(DEFAULTS["density_tissue_mask_from_nuclei"]),
            "density_tissue_mask_ds": int(DEFAULTS["density_tissue_mask_ds"]),
            "density_tissue_dilate_um": float(DEFAULTS["density_tissue_dilate_um"]),
            "density_tissue_close_um": float(DEFAULTS["density_tissue_close_um"]),
            "save_density_mask_debug": bool(self.v_density_mask_debug.get()),

            "compute_zone_area_for_density": bool(DEFAULTS["compute_zone_area_for_density"]),
            "density_area_downsample_factor": int(DEFAULTS["density_area_downsample_factor"]),
            "compute_distance_subzones": bool(DEFAULTS["compute_distance_subzones"]),
            "zones_overlap_darken_factor": float(DEFAULTS["zones_overlap_darken_factor"]),
            "zones_downsample_factor": int(DEFAULTS["zones_downsample_factor"]),
            "zones_overlay_boundaries_blue": bool(DEFAULTS["zones_overlay_boundaries_blue"]),

            "save_debug_boundary_masks": bool(self.v_dbg_bounds.get()),
            "save_debug_nuclei_mask": bool(self.v_dbg_nuclei.get()),

            "png_compression": png_comp,
            "max_basename_len": max_base_len,

            "csv_sep": DEFAULTS["csv_sep"],

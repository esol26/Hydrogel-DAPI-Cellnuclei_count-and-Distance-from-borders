# GUI (Manual Batch Queue, px/µm per job)
# ======================================================================================
class DapiAnalyzeApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("DAPI Analyze - Manual Batch Queue")
        self.geometry("1180x980")
        self.minsize(1180, 980)

        self._ui_queue: "queue.Queue[Tuple[str, Any]]" = queue.Queue()
        self.abort_event = threading.Event()

        # Manual batch queue: list of jobs (px_per_um is job-specific)
        self.batch_jobs: List[Dict[str, str]] = []

        # timer
        self._timer_running = False
        self._timer_t0 = 0.0
        self.v_elapsed = tk.StringVar(value="Dauer: 00:00:00")

        self.run_mode = tk.StringVar(value="count_only")

        # paths
        self.v_dapi = tk.StringVar(value="")
        self.v_outer = tk.StringVar(value="")
        self.v_inner = tk.StringVar(value="")
        self.v_parent_out = tk.StringVar(value="")

        # params
        self.v_px_per_um = tk.StringVar(value=str(DEFAULTS["px_per_um"]))
        self.v_thresholds = tk.StringVar(value=str(DEFAULTS["distance_thresholds_um"]))

        self.v_min_size = tk.StringVar(value=str(DEFAULTS["min_size_px2"]))
        self.v_max_size = tk.StringVar(value=str(DEFAULTS["max_size_px2"]))
        self.v_sigma = tk.StringVar(value=str(DEFAULTS["gaussian_sigma"]))
        self.v_radius = tk.StringVar(value=str(DEFAULTS["local_radius_px"]))

        self.v_watershed = tk.BooleanVar(value=bool(DEFAULTS["do_watershed"]))
        self.v_watershed_h = tk.StringVar(value=str(DEFAULTS["watershed_h_px"]))
        self.v_exclude_edge = tk.BooleanVar(value=bool(DEFAULTS["exclude_edge"]))
        self.v_skeletonize = tk.BooleanVar(value=bool(DEFAULTS["skeletonize_boundary"]))

        # output toggles (ONLY: classes, zones, heatmap)
        self.v_save_classes = tk.BooleanVar(value=bool(DEFAULTS["save_classes_filled"]))
        self.v_save_zones = tk.BooleanVar(value=bool(DEFAULTS["save_distance_zones_image"]))
        self.v_save_local_density = tk.BooleanVar(value=bool(DEFAULTS["save_local_density_map"]))

        self.v_density_cell_um = tk.StringVar(value=str(DEFAULTS["density_cell_um"]))
        self.v_density_colormap = tk.StringVar(value=str(DEFAULTS["density_colormap"]))
        self.v_density_embed = tk.BooleanVar(value=bool(DEFAULTS["density_embed_colorbar"]))

        # debug
        self.v_dbg_bounds = tk.BooleanVar(value=bool(DEFAULTS["save_debug_boundary_masks"]))
        self.v_dbg_nuclei = tk.BooleanVar(value=bool(DEFAULTS["save_debug_nuclei_mask"]))
        self.v_density_mask_debug = tk.BooleanVar(value=bool(DEFAULTS["save_density_mask_debug"]))

        # misc
        self.v_png_comp = tk.StringVar(value=str(DEFAULTS["png_compression"]))
        self.v_max_base_len = tk.StringVar(value=str(DEFAULTS["max_basename_len"]))

        self._build_ui()
        self._apply_mode_rules()

        self.run_mode.trace_add("write", lambda *_: self._apply_mode_rules())
        self.after(100, self._poll_queue)

    # ----- timer -----
    def _timer_start(self):
        self._timer_running = True
        self._timer_t0 = time.perf_counter()
        self._timer_tick()

    def _timer_stop(self):
        self._timer_running = False

    def _timer_tick(self):
        if not self._timer_running:
            return
        dt = max(0.0, time.perf_counter() - self._timer_t0)
        hh = int(dt // 3600)
        mm = int((dt % 3600) // 60)
        ss = int(dt % 60)
        self.v_elapsed.set(f"Dauer: {hh:02d}:{mm:02d}:{ss:02d}")
        self.after(200, self._timer_tick)

    # ----- logging + queue -----
    def _log(self, msg: str):
        self.txt_log.insert("end", str(msg) + "\n")
        self.txt_log.see("end")
        self.update_idletasks()

    def _post_log(self, msg: str):
        self._ui_queue.put(("log", msg))

    def _post_done(self, out_dir: str):
        self._ui_queue.put(("done", out_dir))

    def _post_error(self, msg: str):
        self._ui_queue.put(("error", msg))

    def _poll_queue(self):
        try:
            while True:
                kind, payload = self._ui_queue.get_nowait()
                if kind == "log":
                    self._log(str(payload))
                elif kind == "done":
                    self._timer_stop()
                    self.btn_run.configure(state="normal")
                    self.btn_abort.configure(state="disabled")
                    messagebox.showinfo("Fertig", f"Analyse abgeschlossen.\nOrdner:\n{payload}")
                elif kind == "error":
                    self._timer_stop()
                    self.btn_run.configure(state="normal")
                    self.btn_abort.configure(state="disabled")
                    messagebox.showerror("Fehler", str(payload))
        except queue.Empty:
            pass
        self.after(100, self._poll_queue)

    # ----- UI helpers -----
    def _file_row(self, parent, row, label, var, cmd):
        lbl = ttk.Label(parent, text=label, width=22)
        lbl.grid(row=row, column=0, sticky="w", padx=6, pady=4)
        e = ttk.Entry(parent, textvariable=var, width=92)
        e.grid(row=row, column=1, sticky="ew", padx=6, pady=4)
        b = ttk.Button(parent, text="Suchen...", command=cmd)
        b.grid(row=row, column=2, sticky="w", padx=6, pady=4)
        parent.grid_columnconfigure(1, weight=1)
        return (lbl, e, b)

    def _entry_row(self, parent, row, label, var):
        ttk.Label(parent, text=label).grid(row=row, column=0, sticky="w", pady=4, padx=6)
        ttk.Entry(parent, textvariable=var, width=18).grid(row=row, column=1, sticky="w", padx=6, pady=4)

    def _set_row_enabled(self, widgets, enabled: bool):
        state = "normal" if enabled else "disabled"
        for w in widgets:
            try:
                w.configure(state=state)
            except Exception:
                pass

    # ----- batch queue helpers -----
    def _batch_refresh_view(self):
        for item in self.batch_tree.get_children():
            self.batch_tree.delete(item)

        for idx, job in enumerate(self.batch_jobs, start=1):
            self.batch_tree.insert(
                "",
                "end",
                iid=str(idx),
                values=(
                    idx,
                    job.get("px_per_um", ""),
                    os.path.basename(job.get("dapi", "")),
                    os.path.basename(job.get("outer", "")),
                    os.path.basename(job.get("inner", "")),
                    job.get("parent_out", ""),
                ),
            )

        self.lbl_batch_count.configure(text=f"Jobs in Queue: {len(self.batch_jobs)}")

    def _batch_add_current_selection(self):
        dapi = str(self.v_dapi.get()).strip()
        outer = str(self.v_outer.get()).strip()
        inner = str(self.v_inner.get()).strip()
        parent_out = str(self.v_parent_out.get()).strip()

        try:
            px_per_um_val = float(str(self.v_px_per_um.get()).strip())
        except Exception:
            messagebox.showerror("Ungültig", "Pixel pro µm ist keine Zahl.")
            return
        if px_per_um_val <= 0:
            messagebox.showerror("Ungültig", "Pixel pro µm muss > 0 sein.")
            return

        if not dapi:
            messagebox.showerror("Fehlende Angabe", "Bitte wähle ein DAPI Bild aus.")
            return
        if not parent_out:
            messagebox.showerror("Fehlende Angabe", "Bitte wähle einen Speicherort für die Ergebnisse.")
            return

        if (not outer) or (not inner):
            if not messagebox.askyesno(
                "Grenzen fehlen",
                "Outer/Inner fehlen. Soll der Job trotzdem hinzugefügt werden (dann nur Count-only für diesen Job)?",
            ):
                return

        self.batch_jobs.append({
            "dapi": dapi,
            "outer": outer,
            "inner": inner,
            "parent_out": parent_out,
            "px_per_um": f"{px_per_um_val:g}",
        })
        self._batch_refresh_view()

        # convenience: clear file fields
        self.v_dapi.set("")
        self.v_outer.set("")
        self.v_inner.set("")

    def _batch_remove_selected(self):
        sel = self.batch_tree.selection()
        if not sel:
            return
        idxs = sorted([int(iid) - 1 for iid in sel], reverse=True)
        for i in idxs:
            if 0 <= i < len(self.batch_jobs):
                self.batch_jobs.pop(i)
        self._batch_refresh_view()

    def _batch_clear(self):
        if not self.batch_jobs:
            return
        if not messagebox.askyesno("Queue leeren", "Alle Batch-Jobs entfernen?"):
            return
        self.batch_jobs = []
        self._batch_refresh_view()


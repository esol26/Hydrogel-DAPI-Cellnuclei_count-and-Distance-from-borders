    def _apply_mode_rules(self):
        mode = str(self.run_mode.get())
        is_count_only = (mode == "count_only")
        is_distance_csv = (mode == "distance_csv")
        is_batch = (mode == "batch")

        if is_batch:
            self.frame_batch.pack(fill="x", pady=(10, 0))
            self.lbl_single_info.configure(text="Batch: Auswahl oben → 'Schnitt hinzufügen' → Run arbeitet Queue ab.")
            self._set_row_enabled(self.w_outer, True)
            self._set_row_enabled(self.w_inner, True)
        else:
            self.frame_batch.pack_forget()
            if is_count_only:
                self._set_row_enabled(self.w_outer, False)
                self._set_row_enabled(self.w_inner, False)
                self.lbl_single_info.configure(text="Count-only: nur DAPI + Output nötig.")
            else:
                self._set_row_enabled(self.w_outer, True)
                self._set_row_enabled(self.w_inner, True)
                self.lbl_single_info.configure(text="Distance: DAPI + Outer + Inner + Output wählen.")

        if is_distance_csv:
            # no images in CSV-only
            self.v_save_classes.set(False)
            self.v_save_zones.set(False)
            self.v_save_local_density.set(False)


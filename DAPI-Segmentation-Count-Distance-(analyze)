def _get_bin_edges(n: int, step: int) -> np.ndarray:
    step = max(1, int(step))
    edges = np.arange(0, n + 1, step, dtype=np.int32)
    if edges[-1] != n:
        edges = np.append(edges, n).astype(np.int32)
    return edges


def build_tissue_mask_from_nuclei_mask_downsampled(
    nuclei_mask: np.ndarray,
    px_per_um: float,
    ds: int,
    dilate_um: float,
    close_um: float,
) -> np.ndarray:
    ds = max(1, int(ds))
    m = nuclei_mask[::ds, ::ds].astype(bool)

    r_d = int(max(1, round(float(dilate_um) * float(px_per_um) / float(ds))))
    r_c = int(max(0, round(float(close_um) * float(px_per_um) / float(ds))))

    m = morphology.dilation(m, morphology.disk(r_d))
    if r_c > 0:
        m = morphology.closing(m, morphology.disk(r_c))
    m = ndi.binary_fill_holes(m)
    return m.astype(bool)


def compute_local_density_grid_and_tiles(
    xs_px: np.ndarray,
    ys_px: np.ndarray,
    h: int,
    w: int,
    px_per_um: float,
    cell_um: float,
    area_mask_anyshape: Optional[np.ndarray] = None,
) -> Tuple[np.ndarray, np.ndarray, int, pd.DataFrame]:
    """
    Returns:
      density_grid (nuclei/mm^2) with NaN outside mask,
      counts_grid (nuclei/tile),
      cell_px,
      tiles_df
    """
    cell_px = int(max(1, round(float(cell_um) * float(px_per_um))))

    y_edges = _get_bin_edges(int(h), cell_px)
    x_edges = _get_bin_edges(int(w), cell_px)

    counts, _, _ = np.histogram2d(
        ys_px.astype(np.float32),
        xs_px.astype(np.float32),
        bins=[y_edges.astype(np.float32), x_edges.astype(np.float32)],
    )
    counts = counts.astype(np.float32)

    heights = np.diff(y_edges).astype(np.int32)[:, None]
    widths = np.diff(x_edges).astype(np.int32)[None, :]
    area_px = (heights * widths).astype(np.float32)

    mask_frac = None
    if area_mask_anyshape is not None:
        grid_h, grid_w = area_px.shape
        frac = cv2.resize(area_mask_anyshape.astype(np.float32), (grid_w, grid_h), interpolation=cv2.INTER_AREA)
        frac = np.clip(frac, 0.0, 1.0)
        mask_frac = frac
        area_px = area_px * frac

    area_mm2 = (area_px / float(px_per_um * px_per_um)) / 1e6

    density = np.full_like(area_mm2, np.nan, dtype=np.float32)
    good = area_mm2 > 0
    density[good] = counts[good] / area_mm2[good]

    rows = []
    for i in range(density.shape[0]):
        y0 = int(y_edges[i])
        y1 = int(y_edges[i + 1])
        for j in range(density.shape[1]):
            x0 = int(x_edges[j])
            x1 = int(x_edges[j + 1])
            rows.append({
                "tile_i": int(i),
                "tile_j": int(j),
                "x0_px": x0,
                "x1_px": x1,
                "y0_px": y0,
                "y1_px": y1,
                "x0_um": float(x0 / px_per_um),
                "x1_um": float(x1 / px_per_um),
                "y0_um": float(y0 / px_per_um),
                "y1_um": float(y1 / px_per_um),
                "mask_fraction_est": float(mask_frac[i, j]) if mask_frac is not None else np.nan,
                "area_mm2_est": float(area_mm2[i, j]),
                "count_nuclei": float(counts[i, j]),
                "density_nuclei_per_mm2_est": float(density[i, j]) if np.isfinite(density[i, j]) else np.nan,
            })

    tiles_df = pd.DataFrame(rows)
    return density, counts, cell_px, tiles_df



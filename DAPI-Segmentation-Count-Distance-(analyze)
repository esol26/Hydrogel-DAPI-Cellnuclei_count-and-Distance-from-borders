def parse_thresholds_list(s: str) -> List[float]:
    if s is None:
        return []
    parts = re.split(r"[,\s;]+", str(s).strip())
    parts = [p for p in parts if p]
    vals = [float(p) for p in parts]
    if any(v < 0 for v in vals):
        raise ValueError("Distance thresholds must be >= 0")
    vals_sorted = sorted(vals)
    for i in range(1, len(vals_sorted)):
        if vals_sorted[i] <= vals_sorted[i - 1]:
            raise ValueError("Distance thresholds must be strictly increasing (e.g. 200,500)")
    return vals_sorted


def classify_by_thresholds(dist_um: float, thresholds_um: List[float]) -> int:
    if dist_um < 0:
        return 0
    if len(thresholds_um) == 0:
        return 1
    if dist_um < thresholds_um[0]:
        return 1
    for i in range(1, len(thresholds_um)):
        lo = thresholds_um[i - 1]
        hi = thresholds_um[i]
        if lo <= dist_um <= hi:
            return i + 1
    if dist_um > thresholds_um[-1]:
        return len(thresholds_um) + 1
    return len(thresholds_um)


def class_label(class_code: int, thresholds_um: List[float]) -> str:
    if class_code <= 0:
        return "NA"
    if len(thresholds_um) == 0:
        return "all"
    n = len(thresholds_um)
    if class_code == 1:
        return f"<{thresholds_um[0]}"
    if 2 <= class_code <= n:
        lo = thresholds_um[class_code - 2]
        hi = thresholds_um[class_code - 1]
        return f"{lo}-{hi}"
    if class_code == n + 1:
        return f">{thresholds_um[-1]}"
    return "NA"


def class_to_color_rgb(class_code: int, included: bool, thresholds_um: List[float]) -> Tuple[int, int, int]:
    if not included:
        return (EXCLUDED_GRAY, EXCLUDED_GRAY, EXCLUDED_GRAY)

    # fixed mapping for 2 thresholds -> 3 classes
    if len(thresholds_um) == 2:
        if class_code == 1:
            return (0, 255, 0)      # green
        if class_code == 2:
            return (255, 255, 0)    # yellow
        if class_code == 3:
            return (255, 0, 0)      # red
        return (EXCLUDED_GRAY, EXCLUDED_GRAY, EXCLUDED_GRAY)

    palette_rgb = [
        (0, 255, 0), (255, 255, 0), (255, 0, 0),
        (0, 255, 255), (255, 0, 255), (0, 128, 255),
        (255, 128, 0),
    ]
    idx = max(1, class_code) - 1
    return palette_rgb[idx % len(palette_rgb)]


def darken_rgb_u8(rgb: np.ndarray, factor: float) -> np.ndarray:
    f = float(max(0.0, min(1.0, factor)))
    return np.clip((rgb.astype(np.float32) * f), 0, 255).astype(np.uint8)


def distance_subzone_from_classes(c_min: int, c_outer: int, c_inner: int) -> str:
    if c_min <= 0 or c_outer <= 0 or c_inner <= 0:
        return "none"
    if c_outer == c_inner == c_min:
        return "overlap"
    if c_min == c_outer:
        return "outer_only"
    if c_min == c_inner:
        return "inner_only"
    return "none"


# ======================================================================================
# Segmentation (Phansalkar + global floor + line-artifact removal)
# ======================================================================================
def phansalkar_threshold(img01: np.ndarray, radius: int, k: float = 0.25, r: float = 0.5) -> np.ndarray:
    if radius < 1:
        raise ValueError("local_radius_px must be >= 1")

    p = 2.0
    q = 10.0
    R = float(r)

    size = 2 * radius + 1
    m = ndi.uniform_filter(img01, size=size, mode="reflect")
    m2 = ndi.uniform_filter(img01 * img01, size=size, mode="reflect")
    s = np.sqrt(np.maximum(m2 - m * m, 0.0))

    T = m * (1.0 + p * np.exp(-q * m) + float(k) * ((s / (R + 1e-12)) - 1.0))
    return T


def remove_line_like_components(mask: np.ndarray, max_h: int, min_w: int, min_aspect: float) -> np.ndarray:
    lab = measure.label(mask.astype(bool))
    if lab.max() == 0:
        return mask.astype(bool)

    keep = np.zeros_like(mask, dtype=bool)
    for r in measure.regionprops(lab):
        minr, minc, maxr, maxc = r.bbox
        h = maxr - minr
        w = maxc - minc
        aspect = w / float(h + 1e-6)

        is_line = (h <= int(max_h)) and (w >= int(min_w)) and (aspect >= float(min_aspect))
        if not is_line:
            keep[lab == r.label] = True

    return keep


def make_nuclei_labels(
    dapi_blue: np.ndarray,
    gaussian_sigma: float,
    local_radius_px: int,
    do_watershed: bool,
    watershed_h_px: float,
    exclude_edge: bool,
    min_size_px2: int,
    max_size_px2: int,
    remove_line_artifacts_flag: bool,
    line_max_h: int,
    line_min_w: int,
    line_min_aspect: float,
) -> Tuple[np.ndarray, np.ndarray]:
    img01 = to_float01(dapi_blue)

    if gaussian_sigma and gaussian_sigma > 0:
        img01 = filters.gaussian(img01, sigma=float(gaussian_sigma), preserve_range=True).astype(np.float32)

    # Local threshold
    T_local = phansalkar_threshold(img01, radius=int(local_radius_px))

    # Global floor (Otsu)
    try:
        T_global = float(filters.threshold_otsu(img01))
    except Exception:
        T_global = 0.02
    noise_floor = T_global * 0.3

    mask = (img01 > T_local) & (img01 > noise_floor)

    if int(min_size_px2) > 0:
        mask = morphology.remove_small_objects(mask.astype(bool), min_size=int(min_size_px2))
    else:
        mask = mask.astype(bool)

    mask = ndi.binary_fill_holes(mask)

    if remove_line_artifacts_flag:
        mask = remove_line_like_components(mask, max_h=line_max_h, min_w=line_min_w, min_aspect=line_min_aspect)

    if do_watershed:
        dist = ndi.distance_transform_edt(mask)
        h = float(watershed_h_px)
        if h <= 0:
            labels = measure.label(mask)
        else:
            maxima = morphology.h_maxima(dist, h=h)
            markers = measure.label(maxima)
            if markers.max() == 0:
                markers = measure.label(mask)
            labels = segmentation.watershed(-dist, markers, mask=mask)
    else:
        labels = measure.label(mask)

    if exclude_edge:
        labels = segmentation.clear_border(labels)

    # area filter + relabel
    out = np.zeros_like(labels, dtype=np.int32)
    new_id = 1
    for p in measure.regionprops(labels):
        if p.area < int(min_size_px2) or p.area > int(max_size_px2):
            continue
        out[labels == p.label] = new_id
        new_id += 1

    return out, mask


# ======================================================================================
# Boundary binarization + KDTree
# ======================================================================================
def _score_boundary_mask(b: np.ndarray) -> float:
    n = int(b.sum())
    if n <= 0:
        return -1.0
    frac = n / float(b.size)
    if frac > 0.25:
        return -1.0
    return float(n) * (1.0 - frac)


def binarize_boundary_line(
    boundary_img: np.ndarray,
    debug_dir: Optional[str] = None,
    tag: str = "boundary",
    png_compression: int = 1,
) -> Tuple[np.ndarray, np.ndarray, str]:
    if debug_dir is not None:
        os.makedirs(debug_dir, exist_ok=True)

    candidates: List[Tuple[str, np.ndarray]] = []
    g01 = to_float01(as_gray(boundary_img))

    # Otsu gray
    try:
        t = filters.threshold_otsu(g01)
        b = g01 > t
        if b.mean() > 0.5:
            b = ~b
        candidates.append(("otsu_gray", b))
    except Exception:
        pass

    # Canny
    try:
        g8 = np.clip(g01 * 255.0, 0, 255).astype(np.uint8)
        edges = cv2.Canny(g8, 30, 120) > 0
        edges = morphology.dilation(edges, morphology.disk(1))
        candidates.append(("canny_edges", edges))
    except Exception:
        pass

    # Color heuristics
    if boundary_img.ndim == 3 and boundary_img.shape[-1] in (3, 4):
        rgb01 = to_float01(boundary_img[..., :3])
        nonblack = np.max(rgb01, axis=-1) > 0.03
        candidates.append(("nonblack_rgb", nonblack))

        rgb8 = np.clip(rgb01 * 255.0, 0, 255).astype(np.uint8)
        hsv = cv2.cvtColor(rgb8, cv2.COLOR_RGB2HSV)
        hh = hsv[..., 0].astype(np.int16)
        ss = hsv[..., 1].astype(np.int16)
        vv = hsv[..., 2].astype(np.int16)
        blue_hsv = (hh >= 90) & (hh <= 140) & (ss >= 80) & (vv >= 40)
        candidates.append(("blue_hsv", blue_hsv))

    processed: List[Tuple[str, np.ndarray, np.ndarray, float]] = []
    for name, cand in candidates:
        cand = cand.astype(bool)
        cand_close = morphology.closing(cand, morphology.disk(1))
        s1 = _score_boundary_mask(cand)
        s2 = _score_boundary_mask(cand_close)
        chosen, score = (cand_close, s2) if s2 > s1 else (cand, s1)
        if score < 0:
            continue
        inside = ndi.binary_fill_holes(chosen)
        processed.append((name, chosen, inside, score))

    if not processed:
        raise ValueError(f"Boundary binarization failed (tag={tag}).")

    processed.sort(key=lambda x: x[3], reverse=True)
    best_name, best_bin, best_inside, _ = processed[0]

    if debug_dir is not None:
        save_bool_png(os.path.join(debug_dir, f"{tag}_BEST_{best_name}.png"), best_bin, png_compression=png_compression)
        save_bool_png(os.path.join(debug_dir, f"{tag}_BEST_{best_name}_inside.png"), best_inside, png_compression=png_compression)

    return best_bin, best_inside, best_name


def build_kdtree_from_boundary(boundary_bin: np.ndarray, skeletonize: bool) -> Tuple[cKDTree, int]:
    b = morphology.skeletonize(boundary_bin) if skeletonize else boundary_bin
    if int(b.sum()) == 0:
        b = boundary_bin
    pts = np.column_stack(np.nonzero(b))
    if pts.shape[0] == 0:
        raise ValueError("Boundary mask has 0 pixels after binarization/skeletonize.")
    tree = cKDTree(pts.astype(np.float32))
    return tree, int(pts.shape[0])



            params["save_distance_zones_image"] = False
            params["save_local_density_map"] = False

        return params

    def _run_clicked(self):
        self.abort_event.clear()

        mode = str(self.run_mode.get())
        is_batch = (mode == "batch")
        do_distances = mode in ("distance_csv", "distance_with_images")

        dapi_path = str(self.v_dapi.get()).strip()
        outer_path = str(self.v_outer.get()).strip()
        inner_path = str(self.v_inner.get()).strip()
        parent_out = str(self.v_parent_out.get()).strip()

        if not is_batch:
            if not dapi_path:
                return messagebox.showerror("Fehlende Angabe", "Bitte DAPI auswählen.")
            if do_distances and (not outer_path or not inner_path):
                return messagebox.showerror("Fehlende Angabe", "Für Distanzmodus Outer+Inner auswählen.")
            if not parent_out:
                return messagebox.showerror("Fehlende Angabe", "Bitte Output-Ordner auswählen.")
        else:
            if not self.batch_jobs:
                return messagebox.showerror("Batch-Queue leer", "Bitte erst Jobs mit 'Schnitt hinzufügen' hinzufügen.")

        try:
            params = self._collect_params()
        except Exception as e:
            return messagebox.showerror("Ungültige Parameter", str(e))

        self.btn_run.configure(state="disabled")
        self.btn_abort.configure(state="normal")
        self.v_elapsed.set("Dauer: 00:00:00")
        self._timer_start()
        self._log("Starte...")

        def worker():
            out_dir = None
            try:
                if is_batch:
                    jobs = list(self.batch_jobs)  # snapshot
                    self._post_log(f"{len(jobs)} Jobs in Queue. Starte Batch...")

                    for idx, job in enumerate(jobs, start=1):
                        abort_check(self.abort_event)

                        curr_dapi = job.get("dapi", "")
                        curr_outer = job.get("outer", "")
                        curr_inner = job.get("inner", "")
                        curr_parent_out = job.get("parent_out", "")
                        px_job_str = job.get("px_per_um", "")

                        self._post_log(f"\n--- Job {idx}/{len(jobs)}: {os.path.basename(curr_dapi)} ---")

                        if not curr_dapi or not os.path.isfile(curr_dapi):
                            self._post_log("FEHLER: DAPI Pfad ungültig. Überspringe Job.")
                            continue
                        if not curr_parent_out or not os.path.isdir(curr_parent_out):
                            self._post_log("FEHLER: Output-Ordner ungültig. Überspringe Job.")
                            continue

                        try:
                            px_job = float(px_job_str)
                        except Exception:
                            self._post_log("FEHLER: px/µm im Job ungültig. Überspringe Job.")
                            continue
                        if px_job <= 0:
                            self._post_log("FEHLER: px/µm <= 0. Überspringe Job.")
                            continue

                        has_bounds = bool(curr_outer) and bool(curr_inner) and os.path.isfile(curr_outer) and os.path.isfile(curr_inner)
                        if not has_bounds:
                            self._post_log("WARNUNG: Outer/Inner fehlen -> Job läuft als Count-only.")

                        run_out_dir, base_safe, base_orig = make_run_output_dir(
                            curr_parent_out,
                            curr_dapi,
                            int(params.get("max_basename_len", 60)),
                        )
                        save_run_artifacts(run_out_dir)

                        job_params = dict(params)
                        job_params["px_per_um"] = px_job  # IMPORTANT: image-specific scale

                        analyze_one(
                            dapi_path=curr_dapi,
                            out_dir=run_out_dir,
                            base_safe=base_safe,
                            base_original=base_orig,
                            params=job_params,
                            do_distances=has_bounds,
                            outer_path=curr_outer if has_bounds else None,
                            inner_path=curr_inner if has_bounds else None,
                            log_fn=self._post_log,
                            abort_event=self.abort_event,
                        )

                        gc.collect()

                    self._post_log("\nBatch fertig.")
                    self._post_done(jobs[-1].get("parent_out", "") if jobs else "")
                    return

                # single run
                out_dir, base_safe, base_orig = make_run_output_dir(
                    parent_out,
                    dapi_path,
                    int(params.get("max_basename_len", 60)),
                )
                save_run_artifacts(out_dir)
                self._post_log(f"Output: {out_dir}")

                analyze_one(
                    dapi_path=dapi_path,
                    out_dir=out_dir,
                    base_safe=base_safe,
                    base_original=base_orig,
                    params=params,
                    do_distances=do_distances,
                    outer_path=outer_path if do_distances else None,
                    inner_path=inner_path if do_distances else None,
                    log_fn=self._post_log,
                    abort_event=self.abort_event,
                )

                gc.collect()
                self._post_done(out_dir)

            except AbortRequested:
                self._post_error("Abgebrochen.")
            except Exception:
                err = traceback.format_exc()
                if out_dir:
                    try:
                        with open(os.path.join(out_dir, "error_traceback.txt"), "w", encoding="utf-8") as f:
                            f.write(err)
                    except Exception:
                        pass
                self._post_log(err)
                self._post_error("Kritischer Fehler. Siehe Log / error_traceback.txt.")

        threading.Thread(target=worker, daemon=True).start()



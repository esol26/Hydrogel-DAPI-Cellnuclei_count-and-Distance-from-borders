def build_distance_zones_image_downsampled_rgb_with_overlap(
    outer_inside: np.ndarray,
    inner_inside: np.ndarray,
    outer_bin: np.ndarray,
    inner_bin: np.ndarray,
    outer_tree: cKDTree,
    inner_tree: cKDTree,
    px_per_um: float,
    thresholds_um: List[float],
    ds: int,
    overlay_boundaries_blue: bool,
    overlap_darken_factor: float,
    abort_event: Optional[threading.Event],
) -> np.ndarray:
    ds = max(1, int(ds))
    ring = outer_inside & (~inner_inside)
    ring_ds = ring[::ds, ::ds]

    outer_bin_ds = outer_bin[::ds, ::ds]
    inner_bin_ds = inner_bin[::ds, ::ds]

    h_ds, w_ds = ring_ds.shape
    rgb = np.zeros((h_ds, w_ds, 3), dtype=np.uint8)

    ys, xs = np.nonzero(ring_ds)
    if ys.size == 0:
        if overlay_boundaries_blue:
            rgb[(outer_bin_ds | inner_bin_ds)] = (0, 0, 255)
        return rgb

    abort_check(abort_event)

    pts = np.stack([ys.astype(np.float32) * ds, xs.astype(np.float32) * ds], axis=1)
    d_outer_px, _ = outer_tree.query(pts, k=1)
    abort_check(abort_event)
    d_inner_px, _ = inner_tree.query(pts, k=1)

    d_outer_um = d_outer_px / float(px_per_um)
    d_inner_um = d_inner_px / float(px_per_um)
    d_min_um = np.minimum(d_outer_um, d_inner_um)

    if len(thresholds_um) == 0:
        c_outer = np.ones_like(d_outer_um, dtype=np.int32)
        c_inner = np.ones_like(d_inner_um, dtype=np.int32)
        c_min = np.ones_like(d_min_um, dtype=np.int32)
    else:
        th = np.array(thresholds_um, dtype=np.float32)
        c_outer = np.digitize(d_outer_um, th, right=False).astype(np.int32) + 1
        c_inner = np.digitize(d_inner_um, th, right=False).astype(np.int32) + 1
        c_min = np.digitize(d_min_um, th, right=False).astype(np.int32) + 1

    # LUT colors for classes
    max_cls = int(np.max(c_min)) if c_min.size else 1
    lut = np.zeros((max_cls + 1, 3), dtype=np.uint8)
    for cls in range(1, max_cls + 1):
        lut[cls] = np.array(class_to_color_rgb(cls, True, thresholds_um), dtype=np.uint8)

    base_colors = lut[c_min]  # (N,3)

    overlap = (c_outer == c_inner) & (c_outer == c_min)
    if np.any(overlap):
        base_colors[overlap] = darken_rgb_u8(base_colors[overlap], overlap_darken_factor)

    rgb[ys, xs] = base_colors

    if overlay_boundaries_blue:
        rgb[(outer_bin_ds | inner_bin_ds)] = (0, 0, 255)

    return rgb


def estimate_area_by_class_and_subzone_mm2(
    outer_inside: np.ndarray,
    inner_inside: np.ndarray,
    outer_tree: cKDTree,
    inner_tree: cKDTree,
    px_per_um: float,
    thresholds_um: List[float],
    ds: int,
    abort_event: Optional[threading.Event],
) -> pd.DataFrame:
    ds = max(1, int(ds))
    ring = outer_inside & (~inner_inside)
    ring_ds = ring[::ds, ::ds]
    ys, xs = np.nonzero(ring_ds)
    if ys.size == 0:
        return pd.DataFrame(columns=["DistanceClass", "DistanceSubzone", "Area_mm2_est"])

    abort_check(abort_event)

    pts = np.stack([ys.astype(np.float32) * ds, xs.astype(np.float32) * ds], axis=1)
    d_outer_px, _ = outer_tree.query(pts, k=1)
    abort_check(abort_event)
    d_inner_px, _ = inner_tree.query(pts, k=1)

    d_outer_um = d_outer_px / float(px_per_um)
    d_inner_um = d_inner_px / float(px_per_um)
    d_min_um = np.minimum(d_outer_um, d_inner_um)

    if len(thresholds_um) == 0:
        c_outer = np.ones_like(d_outer_um, dtype=np.int32)
        c_inner = np.ones_like(d_inner_um, dtype=np.int32)
        c_min = np.ones_like(d_min_um, dtype=np.int32)
    else:
        th = np.array(thresholds_um, dtype=np.float32)
        c_outer = np.digitize(d_outer_um, th, right=False).astype(np.int32) + 1
        c_inner = np.digitize(d_inner_um, th, right=False).astype(np.int32) + 1
        c_min = np.digitize(d_min_um, th, right=False).astype(np.int32) + 1

    overlap = (c_outer == c_inner) & (c_outer == c_min)
    outer_only = (~overlap) & (c_min == c_outer)
    inner_only = (~overlap) & (c_min == c_inner)

    pixel_area_mm2 = px_area_to_mm2(int(ds * ds), px_per_um)

    rows = []
    for cls in sorted(np.unique(c_min).tolist()):
        for name, m in [("outer_only", outer_only), ("inner_only", inner_only), ("overlap", overlap)]:
            n = int(np.sum((c_min == cls) & m))
            if n > 0:
                rows.append({
                    "DistanceClass": int(cls),
                    "DistanceSubzone": name,
                    "Area_mm2_est": float(n) * float(pixel_area_mm2),
                })

    return pd.DataFrame(rows)



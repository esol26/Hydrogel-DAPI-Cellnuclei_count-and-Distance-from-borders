# Heatmap (fixed COUNT scale 0..25, turbo/jet)
# ======================================================================================
def _colormap_id(colormap: str) -> int:
    cm = str(colormap).strip().lower()
    if cm == "turbo" and hasattr(cv2, "COLORMAP_TURBO"):
        return cv2.COLORMAP_TURBO
    return cv2.COLORMAP_JET


def counts_to_colormap_bgr_fixed(
    counts: np.ndarray,
    vmin: float,
    vmax: float,
    colormap: str,
    excluded_gray: int,
    valid_mask: Optional[np.ndarray] = None,
) -> np.ndarray:
    c = counts.astype(np.float32, copy=False)
    valid = np.isfinite(c) if valid_mask is None else (valid_mask.astype(bool) & np.isfinite(c))

    eg = int(max(0, min(255, int(excluded_gray))))
    out = np.zeros((c.shape[0], c.shape[1], 3), dtype=np.uint8)
    out[:] = (eg, eg, eg)

    if not np.any(valid):
        return out

    lo = float(vmin)
    hi = float(vmax)
    if hi <= lo:
        hi = lo + 1.0

    x = np.clip((c - lo) / (hi - lo), 0.0, 1.0)
    u8 = (x * 255.0).astype(np.uint8)

    colored = cv2.applyColorMap(u8, _colormap_id(colormap))
    out[valid] = colored[valid]
    return out


def make_colormap_colorbar_bgr(
    vmin: float,
    vmax: float,
    colormap: str,
    width: int,
    height: int,
    title: str = "nuclei/tile",
) -> np.ndarray:
    width = max(70, int(width))
    height = max(160, int(height))

    grad = np.linspace(1.0, 0.0, height, dtype=np.float32)[:, None]
    u8 = (grad * 255.0).astype(np.uint8)
    u8 = np.repeat(u8, width, axis=1)

    bar = cv2.applyColorMap(u8, _colormap_id(colormap))
    canvas = bar.copy()

    font = cv2.FONT_HERSHEY_SIMPLEX
    cv2.putText(canvas, title, (5, 18), font, 0.5, (255, 255, 255), 1, cv2.LINE_AA)
    cv2.putText(canvas, f"{vmax:.0f}", (5, 44), font, 0.65, (255, 255, 255), 1, cv2.LINE_AA)
    cv2.putText(canvas, f"{vmin:.0f}", (5, height - 10), font, 0.65, (255, 255, 255), 1, cv2.LINE_AA)
    return canvas


def embed_colorbar_into_heatmap(heat_bgr: np.ndarray, colorbar_bgr: np.ndarray, side: str, pad: int) -> np.ndarray:
    side = str(side).strip().lower()
    pad = max(0, int(pad))

    if side == "bottom":
        spacer = np.zeros((pad, heat_bgr.shape[1], 3), dtype=np.uint8)
        cb = cv2.resize(colorbar_bgr, (heat_bgr.shape[1], colorbar_bgr.shape[0]), interpolation=cv2.INTER_NEAREST)
        return np.vstack([heat_bgr, spacer, cb])

    spacer = np.zeros((heat_bgr.shape[0], pad, 3), dtype=np.uint8)
    cb = cv2.resize(colorbar_bgr, (colorbar_bgr.shape[1], heat_bgr.shape[0]), interpolation=cv2.INTER_NEAREST)
    return np.hstack([heat_bgr, spacer, cb])



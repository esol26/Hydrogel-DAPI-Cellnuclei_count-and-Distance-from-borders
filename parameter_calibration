# -------------------- Image helpers --------------------
def list_images(folder: str) -> list[str]:
    out: list[str] = []
    for fn in sorted(os.listdir(folder)):
        ext = os.path.splitext(fn)[1].lower()
        if ext in SUPPORTED_IMAGE_EXTS:
            out.append(os.path.join(folder, fn))
    return out


def read_image_any(path: str) -> tuple[np.ndarray, str]:
    """
    Returns (image, source) where source is "tiff" or "cv2".
    """
    ext = os.path.splitext(path)[1].lower()
    if ext in [".tif", ".tiff"]:
        return tiff.imread(path), "tiff"

    img = cv2.imread(path, cv2.IMREAD_UNCHANGED)
    if img is None:
        raise ValueError(f"Could not read image: {path}")
    return img, "cv2"


def extract_dapi_channel(img: np.ndarray, source: str) -> np.ndarray:
    """
    Returns a 2D array used for segmentation.

    - cv2 loads color as BGR -> DAPI typically in BLUE => channel 0
    - tifffile often yields RGB for color -> BLUE => channel 2
    """
    if img.ndim == 2:
        return img

    if img.ndim == 3:
        # HWC
        if img.shape[-1] >= 3:
            if source == "cv2":
                return img[..., 0]  # BGR blue
            return img[..., 2]      # RGB blue

        # CHW
        if img.shape[0] >= 3:
            if source == "cv2":
                return img[0, ...]
            return img[2, ...]

        return np.max(img, axis=0)

    raise ValueError(f"Unsupported image shape: {img.shape}")


def to_float01(img: np.ndarray) -> np.ndarray:
    img = img.astype(np.float32, copy=False)
    mn = float(np.nanmin(img))
    mx = float(np.nanmax(img))
    if mx <= mn:
        return np.zeros_like(img, dtype=np.float32)
    return (img - mn) / (mx - mn)


def write_png(path: str, img: np.ndarray, png_compression: int) -> None:
    comp = int(max(0, min(9, png_compression)))
    ok = cv2.imwrite(path, img, [cv2.IMWRITE_PNG_COMPRESSION, comp])
    if not ok:
        raise ValueError(f"Could not write PNG: {path}")


# -------------------- Segmentation --------------------
def phansalkar_threshold(img01: np.ndarray, radius: int, k: float = 0.25, r: float = 0.5) -> np.ndarray:
    if radius < 1:
        raise ValueError("local_radius_px must be >= 1")

    p = 2.0
    q = 10.0
    R = float(r)

    size = 2 * radius + 1
    m = ndi.uniform_filter(img01, size=size, mode="reflect")
    m2 = ndi.uniform_filter(img01 * img01, size=size, mode="reflect")
    s = np.sqrt(np.maximum(m2 - m * m, 0.0))

    T = m * (1.0 + p * np.exp(-q * m) + float(k) * ((s / (R + 1e-12)) - 1.0))
    return T


def remove_small_objects_compat(mask: np.ndarray, min_size_px2: int) -> np.ndarray:
    varnames = morphology.remove_small_objects.__code__.co_varnames
    if "max_size" in varnames:
        max_size = int(min_size_px2) - 1
        if max_size < 0:
            return mask
        return morphology.remove_small_objects(mask, max_size=max_size)
    return morphology.remove_small_objects(mask, min_size=int(min_size_px2))


def make_nuclei_labels_from_img01(
    img01: np.ndarray,
    gaussian_sigma: float,
    local_radius_px: int,
    min_size_px2: int,
    max_size_px2: int,
    do_watershed: bool,
    watershed_h_px: float,
    exclude_edge: bool,
) -> tuple[np.ndarray, np.ndarray]:
    x = img01

    if gaussian_sigma > 0:
        x = filters.gaussian(x, sigma=float(gaussian_sigma), preserve_range=True).astype(np.float32)

    T = phansalkar_threshold(x, radius=int(local_radius_px))
    mask = x > T

    mask = remove_small_objects_compat(mask, int(min_size_px2))
    mask = ndi.binary_fill_holes(mask)

    if do_watershed:
        dist = ndi.distance_transform_edt(mask)
        h = float(watershed_h_px)

        if h <= 0:
            labels = measure.label(mask)
        else:
            maxima = morphology.h_maxima(dist, h=h)
            markers = measure.label(maxima)
            if int(markers.max()) == 0:
                markers = measure.label(mask)
            labels = segmentation.watershed(-dist, markers, mask=mask)
    else:
        labels = measure.label(mask)

    if exclude_edge:
        labels = segmentation.clear_border(labels)

    out = np.zeros_like(labels, dtype=np.int32)
    new_id = 1
    for p in measure.regionprops(labels):
        if p.area < int(min_size_px2) or p.area > int(max_size_px2):
            continue
        out[labels == p.label] = new_id
        new_id += 1

    return out, mask


# -------------------- Parameter grid --------------------
PARAM_TYPES = {
    "gaussian_sigma": "float",
    "watershed_h_px": "float",
    "local_radius_px": "int",
    "min_size_px2": "int",
    "max_size_px2": "int",
    "do_watershed": "bool",
    "exclude_edge": "bool",
}
REQUIRED_PARAMS = list(PARAM_TYPES.keys())


def parse_range_csv(csv_path: str) -> dict[str, dict]:
    df = pd.read_csv(csv_path)
    df.columns = [c.strip().lower() for c in df.columns]

    expected = ["parameter", "min", "max", "step"]
    for c in expected:
        if c not in df.columns:
            raise ValueError(f"Parameter CSV missing column '{c}'. Expected columns: {expected}")

    out: dict[str, dict] = {}
    for _, r in df.iterrows():
        p = str(r["parameter"]).strip()
        if p == "" or p.lower().startswith("#"):
            continue
        if p not in PARAM_TYPES:
            continue
        out[p] = {"min": float(r["min"]), "max": float(r["max"]), "step": float(r["step"])}

    missing = [p for p in REQUIRED_PARAMS if p not in out]
    if missing:
        raise ValueError(f"Parameter CSV missing required parameters: {missing}")
    return out


def values_from_range(p: str, rmin: float, rmax: float, step: float) -> list:
    ptype = PARAM_TYPES[p]

    if ptype == "bool":
        if rmin <= 0 <= rmax and rmin <= 1 <= rmax:
            return [False, True]
        return [bool(round(rmax))]

    if step <= 0:
        raise ValueError(f"Step must be > 0 for parameter '{p}'")

    n = int(math.floor((rmax - rmin) / step + 1e-9)) + 1
    vals = [rmin + i * step for i in range(n)]
    vals = [v for v in vals if v <= rmax + 1e-9]

    if ptype == "int":
        vals_int = sorted(set(int(round(v)) for v in vals))
        if p == "local_radius_px":
            vals_int = [v for v in vals_int if v >= 1]
        if p in ("min_size_px2", "max_size_px2"):
            vals_int = [v for v in vals_int if v >= 1]
        return vals_int

    return [float(v) for v in vals]


def build_param_grid(ranges: dict[str, dict]) -> tuple[list[str], list[list]]:
    names = REQUIRED_PARAMS[:]
    all_values = []
    for p in names:
        r = ranges[p]
        vals = values_from_range(p, r["min"], r["max"], r["step"])
        if len(vals) == 0:
            raise ValueError(f"No values produced for '{p}'. Check min/max/step.")
        all_values.append(vals)
    return names, all_values


def combos_total_from_all_values(all_values: list[list]) -> int:
    total = 1
    for vals in all_values:
        total *= len(vals)
    return int(total)


def params_from_combo(names: list[str], combo: tuple) -> dict:
    d = dict(zip(names, combo))

    d["gaussian_sigma"] = float(d["gaussian_sigma"])
    d["watershed_h_px"] = float(d["watershed_h_px"])
    d["local_radius_px"] = int(d["local_radius_px"])
    d["min_size_px2"] = int(d["min_size_px2"])
    d["max_size_px2"] = int(d["max_size_px2"])
    d["do_watershed"] = bool(d["do_watershed"])
    d["exclude_edge"] = bool(d["exclude_edge"])

    if d["local_radius_px"] < 1:
        return {}
    if d["min_size_px2"] < 1 or d["max_size_px2"] < 1:
        return {}
    if d["max_size_px2"] < d["min_size_px2"]:
        return {}
    return d


# -------------------- Helpers for per-image column naming --------------------
def sanitize_col_token(name: str) -> str:
    s = os.path.splitext(os.path.basename(name))[0]
    s = re.sub(r"[^A-Za-z0-9_]+", "_", s)
    s = re.sub(r"_+", "_", s).strip("_")
    if s == "":
        s = "image"
    return s


def unique_tokens(basenames: list[str]) -> dict[str, str]:
    used: set[str] = set()
    out: dict[str, str] = {}
    for bn in basenames:
        base = sanitize_col_token(bn)
        tok = base
        i = 2
        while tok in used:
            tok = f"{base}_{i}"
            i += 1
        used.add(tok)
        out[bn] = tok
    return out


# -------------------- Stage schedule + image order --------------------
def keep_fraction_for_stage(stage_idx: int) -> float:
    if stage_idx == 1:
        return float(STAGE1_KEEP_FRAC)
    if stage_idx == 2:
        return float(STAGE2_KEEP_FRAC)
    return float(STAGE3PLUS_KEEP_FRAC)


def order_images_by_gt_zigzag(images: list[str], gt_map: dict[str, int]) -> list[str]:
    """
    Deterministic "diverse early" ordering:
    sort by GT then take: median, low, high, 2nd low, 2nd high, ...
    """
    rows = []
    for p in images:
        bn = os.path.basename(p)
        rows.append((int(gt_map[bn]), bn, p))
    rows.sort(key=lambda t: (t[0], t[1]))
    ps = [t[2] for t in rows]
    if len(ps) <= 2:
        return ps

    mid = len(ps) // 2
    out = [ps[mid]]
    used = {mid}
    lo, hi = 0, len(ps) - 1
    toggle = True

    while len(out) < len(ps):
        if toggle:
            if lo not in used:
                out.append(ps[lo])
                used.add(lo)
            lo += 1
        else:
            if hi not in used:
                out.append(ps[hi])
                used.add(hi)
            hi -= 1
        toggle = not toggle

        if lo > hi and len(out) < len(ps):
            for i in range(len(ps)):
                if i not in used:
                    out.append(ps[i])
                    used.add(i)
    return out


